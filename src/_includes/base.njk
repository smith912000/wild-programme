<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }}</title>
{% if description %}<meta name="description" content="{{ description }}">{% endif %}
<meta property="og:type" content="website" />
<meta property="og:title" content="{{ ogTitle or title }}" />
<meta property="og:description" content="{{ ogDescription or description }}" />
{% if ogUrl %}<meta property="og:url" content="{{ ogUrl }}" />{% endif %}
<meta property="og:image" content="https://smith912000.github.io/wild-programme/og-image.png" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="{{ ogTitle or title }}" />
<meta name="twitter:image" content="https://smith912000.github.io/wild-programme/og-image.png" />
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 120'%3E%3Crect width='100' height='120' fill='%23050309'/%3E%3Cg fill='none' stroke='%236349B8' stroke-width='3'%3E%3Ccircle cx='50' cy='44' r='34'/%3E%3Ccircle cx='50' cy='76' r='34'/%3E%3C/g%3E%3Cline x1='50' y1='52' x2='50' y2='68' stroke='%23C9A84C' stroke-width='4' stroke-linecap='round'/%3E%3C/svg%3E">
{% if fonts %}<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&display=swap" rel="stylesheet">{% endif %}
{% if headExtra %}{{ headExtra | safe }}{% endif %}
<script src="{{ '/assets/analytics.js' | url }}"></script>
</head>
<body>
{{ content | safe }}
<script id="wild-consent-js" data-legal="{{ '/02 - Landing Pages/legal.html' | url }}" src="{{ '/assets/consent.js' | url }}" defer></script>
</body>
</html>
