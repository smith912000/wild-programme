# Supabase — create a project at https://supabase.com
# Copy Project URL and anon key from Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Without these, the app runs in DEMO MODE (data stored in browser IndexedDB)
# Demo unlock codes:
#   WILD-FOUND-2024  →  Tier 1 (Foundations)
#   WILD-ADV-2024    →  Tier 2 (Advanced)
#   WILD-MAST-2024   →  Tier 3 (Master)
